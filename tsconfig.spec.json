{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Project */
    "outDir": "./node_modules/.out-tsc/spec",

    /* Language & Environment */
    "types": ["jest", "jest-extended", "node"],

    /* Modules */
    "module": "CommonJs",
    "isolatedModules": true,
    "allowJs": true
  },
  "include": ["src/**/*.spec.ts", "src/**/*.d.ts"]
}
