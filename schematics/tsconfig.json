{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src/",
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "strict": true,
    "strictNullChecks": false, // TODO: enable and fix ~196 null-safety issues
    "strictFunctionTypes": false, // TODO: enable and fix tsquery Node[] callback typings
    "useUnknownInCatchVariables": false, // TODO: enable and fix catch clause typings
    "noEmitOnError": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["jest", "jest-extended", "node"],
    "noFallthroughCasesInSwitch": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "paths": {
      "schemas/*": ["dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/*/files/**/*", "src/*/other-files/**/*"]
}
