{
  "compilerOptions": {
    /* Project */
    "baseUrl": ".",
    "rootDir": "src/",
    "outDir": "dist",
    "paths": {
      "schemas/*": ["dist/*"]
    },

    /* Language & Environment */
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["jest", "jest-extended", "node"],

    /* Modules */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Type Checking */
    "strict": true,
    "strictNullChecks": false, // TODO: enable and fix ~196 null-safety issues
    "strictFunctionTypes": false, // TODO: enable and fix tsquery Node[] callback typings
    "useUnknownInCatchVariables": false, // TODO: enable and fix catch clause typings
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Emit */
    "sourceMap": true,
    "noEmitOnError": false,

    /* Interop */
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/*/files/**/*", "src/*/other-files/**/*"]
}
