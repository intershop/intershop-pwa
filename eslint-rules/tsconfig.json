{
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": false, // TODO: enable and fix ~28 null-safety issues
    "noImplicitAny": false, // TODO: enable and fix ~10 implicit any issues
    "declaration": false,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "skipLibCheck": true,
    "target": "ES2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*.ts"]
}
