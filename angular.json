{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "intershop-pwa": {
      "projectType": "application",
      "cli": {
        "schematicCollections": ["intershop-schematics"]
      },
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "ish",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./templates/webpack/webpack.custom.ts",
              "replaceDuplicatePlugins": true
            },
            "outputPath": "dist/browser",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/assets",
              {
                "glob": "favicon.ico",
                "input": "src/assets/themes/theme_placeholder/img/",
                "output": "/"
              }
            ],
            "scripts": [],
            "styles": ["src/styles/themes/theme_placeholder/style.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["src/styles/themes/theme_placeholder"]
            },
            "sourceMap": true,
            "allowedCommonJsDependencies": ["localforage"]
          },
          "defaultConfiguration": "b2b,production",
          "configurations": {
            "production": {
              "outputHashing": "all",
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": true,
              "commonChunk": false,
              "budgets": [
                {
                  "type": "bundle",
                  "name": "main",
                  "maximumWarning": "500kb",
                  "maximumError": "600kb"
                },
                {
                  "type": "bundle",
                  "name": "vendor",
                  "maximumWarning": "900kb",
                  "maximumError": "1000kb"
                },
                {
                  "type": "initial",
                  "maximumWarning": "1.6mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "5kb",
                  "maximumError": "10kb"
                }
              ],
              "serviceWorker": false,
              "ngswConfigPath": "ngsw-config.json",
              "fileReplacements": [
                {
                  "replace": "src/app/core/store/store-devtools.module.ts",
                  "with": "src/app/core/store/store-devtools.module.production.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "buildOptimizer": false,
              "tsConfig": "tsconfig.app-no-checks.json",
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            },
            "b2b": {},
            "b2c": {}
          }
        },
        "build-application": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": {
              "base": "dist/application-builder",
              "browser": "browser",
              "server": "server"
            },
            "index": "src/index.html",
            "browser": "src/main.ts",
            "server": "src/main.server.ts",
            "polyfills": ["src/polyfills.ts"],
            "tsConfig": "tsconfig.application-builder.json",
            "assets": [
              "src/assets",
              {
                "glob": "favicon.ico",
                "input": "src/assets/themes/b2b/img/",
                "output": "/"
              }
            ],
            "scripts": [],
            "styles": ["src/styles/themes/b2b/style.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["src/styles/themes/b2b"],
              "sass": {
                "silenceDeprecations": [
                  "mixed-decls",
                  "color-functions",
                  "global-builtin",
                  "import"
                ]
              }
            },
            "sourceMap": true,
            "allowedCommonJsDependencies": ["js-yaml", "localforage"],
            "externalDependencies": ["elastic-apm-node"],
            "define": {
              "PWA_VERSION": "\"11.1.0 application-builder - configuration:b2b,production service-worker:false\"",
              "PRODUCTION_MODE": "true",
              "SERVICE_WORKER": "false",
              "NGRX_RUNTIME_CHECKS": "false",
              "THEME": "\"b2b\"",
              "SSR": "globalThis.ngServerMode"
            },
            "ssr": {
              "entry": "server.ts"
            },
            "prerender": false
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "bundle",
                  "name": "main",
                  "maximumWarning": "500kb",
                  "maximumError": "600kb"
                },
                {
                  "type": "initial",
                  "maximumWarning": "1.6mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "5kb",
                  "maximumError": "10kb"
                }
              ],
              "serviceWorker": false,
              "fileReplacements": [
                {
                  "replace": "src/app/core/store/store-devtools.module.ts",
                  "with": "src/app/core/store/store-devtools.module.production.ts"
                },
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.b2b.ts"
                }
              ]
            },
            "b2b": {
              "styles": ["src/styles/themes/b2b/style.scss"],
              "stylePreprocessorOptions": {
                "includePaths": ["src/styles/themes/b2b"],
                "sass": {
                  "silenceDeprecations": [
                    "mixed-decls",
                    "color-functions",
                    "global-builtin",
                    "import"
                  ]
                }
              },
              "assets": [
                "src/assets",
                {
                  "glob": "favicon.ico",
                  "input": "src/assets/themes/b2b/img/",
                  "output": "/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.b2b.ts"
                }
              ]
            },
            "b2c": {
              "styles": ["src/styles/themes/b2c/style.scss"],
              "stylePreprocessorOptions": {
                "includePaths": ["src/styles/themes/b2c"],
                "sass": {
                  "silenceDeprecations": [
                    "mixed-decls",
                    "color-functions",
                    "global-builtin",
                    "import"
                  ]
                }
              },
              "assets": [
                "src/assets",
                {
                  "glob": "favicon.ico",
                  "input": "src/assets/themes/b2c/img/",
                  "output": "/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.b2c.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true,
              "extractLicenses": false,
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            },
            "b2b-serve-development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true,
              "extractLicenses": false,
              "server": false,
              "ssr": false,
              "prerender": false,
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ],
              "styles": ["src/styles/themes/b2b/style.scss"],
              "stylePreprocessorOptions": {
                "includePaths": ["src/styles/themes/b2b"],
                "sass": {
                  "silenceDeprecations": [
                    "mixed-decls",
                    "color-functions",
                    "global-builtin",
                    "import"
                  ]
                }
              },
              "assets": [
                "src/assets",
                {
                  "glob": "favicon.ico",
                  "input": "src/assets/themes/b2b/img/",
                  "output": "/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.b2b.ts"
                }
              ]
            },
            "b2c-serve-development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true,
              "extractLicenses": false,
              "server": false,
              "ssr": false,
              "prerender": false,
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ],
              "styles": ["src/styles/themes/b2c/style.scss"],
              "stylePreprocessorOptions": {
                "includePaths": ["src/styles/themes/b2c"],
                "sass": {
                  "silenceDeprecations": [
                    "mixed-decls",
                    "color-functions",
                    "global-builtin",
                    "import"
                  ]
                }
              },
              "assets": [
                "src/assets",
                {
                  "glob": "favicon.ico",
                  "input": "src/assets/themes/b2c/img/",
                  "output": "/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.b2c.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "b2b,production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "defaultConfiguration": "b2b",
          "options": {
            "buildTarget": "intershop-pwa:build-application:b2b-serve-development"
          },
          "configurations": {
            "production": {
              "buildTarget": "intershop-pwa:build-application:b2b,production"
            },
            "development": {
              "buildTarget": "intershop-pwa:build-application:b2b-serve-development"
            },
            "b2b": {
              "buildTarget": "intershop-pwa:build-application:b2b-serve-development"
            },
            "b2c": {
              "buildTarget": "intershop-pwa:build-application:b2c-serve-development"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "intershop-pwa:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "**/*.ts",
              "**/*.mts",
              "**/*.js",
              "**/*.mjs",
              "**/*.html"
            ]
          }
        },
        "server": {
          "builder": "@angular-builders/custom-webpack:server",
          "options": {
            "customWebpackConfig": {
              "path": "./templates/webpack/webpack.custom.ts",
              "replaceDuplicatePlugins": true
            },
            "outputPath": "dist/server",
            "main": "server.ts",
            "optimization": true,
            "tsConfig": "tsconfig.server.json",
            "stylePreprocessorOptions": {
              "includePaths": ["src/styles/themes/theme_placeholder"]
            },
            "sourceMap": true
          },
          "defaultConfiguration": "b2b,production",
          "configurations": {
            "production": {},
            "development": {},
            "b2b": {},
            "b2c": {}
          }
        },
        "serve-ssr": {
          "builder": "@angular-devkit/build-angular:ssr-dev-server",
          "options": {
            "browserTarget": "intershop-pwa:build",
            "serverTarget": "intershop-pwa:server"
          },
          "defaultConfiguration": "b2b",
          "configurations": {
            "b2b": {
              "browserTarget": "intershop-pwa:build:b2b,development",
              "serverTarget": "intershop-pwa:server:b2b,development"
            },
            "b2c": {
              "browserTarget": "intershop-pwa:build:b2c,development",
              "serverTarget": "intershop-pwa:server:b2c,development"
            }
          }
        },
        "serve-webpack": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "buildTarget": "intershop-pwa:build"
          },
          "defaultConfiguration": "b2b,development",
          "configurations": {
            "production": {
              "buildTarget": "intershop-pwa:build:production"
            },
            "development": {
              "buildTarget": "intershop-pwa:build:development"
            },
            "b2b": {
              "buildTarget": "intershop-pwa:build:b2b"
            },
            "b2c": {
              "buildTarget": "intershop-pwa:build:b2c"
            }
          }
        }
      }
    },
    "organization-management": {
      "projectType": "application",
      "cli": {
        "schematicCollections": ["intershop-schematics"]
      },
      "root": "projects/organization-management",
      "sourceRoot": "projects/organization-management/src",
      "prefix": "ish",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./templates/webpack/webpack.custom.ts",
              "replaceDuplicatePlugins": true
            },
            "outputPath": "dist/organization-management",
            "index": "projects/organization-management/src/index.html",
            "main": "projects/organization-management/src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "projects/organization-management/tsconfig.app.json",
            "aot": false,
            "styles": ["src/styles/themes/theme_placeholder/style.scss"],
            "assets": [
              {
                "glob": "**/*",
                "input": "src/assets/",
                "output": "/assets/"
              }
            ],
            "scripts": [],
            "fileReplacements": [
              {
                "replace": "src/environments/environment.ts",
                "with": "src/environments/environment.development.ts"
              }
            ]
          }
        },
        "serve": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "buildTarget": "organization-management:build"
          }
        }
      }
    },
    "requisition-management": {
      "projectType": "application",
      "cli": {
        "schematicCollections": ["intershop-schematics"]
      },
      "root": "projects/requisition-management",
      "sourceRoot": "projects/requisition-management/src",
      "prefix": "ish",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./templates/webpack/webpack.custom.ts",
              "replaceDuplicatePlugins": true
            },
            "outputPath": "dist/requisition-management",
            "index": "projects/requisition-management/src/index.html",
            "main": "projects/requisition-management/src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "projects/requisition-management/tsconfig.app.json",
            "aot": false,
            "styles": ["src/styles/themes/theme_placeholder/style.scss"],
            "assets": [
              {
                "glob": "**/*",
                "input": "src/assets/",
                "output": "/assets/"
              }
            ],
            "scripts": [],
            "fileReplacements": [
              {
                "replace": "src/environments/environment.ts",
                "with": "src/environments/environment.development.ts"
              }
            ]
          }
        },
        "serve": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "buildTarget": "requisition-management:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false,
    "cache": {
      "path": ".angular\\cache\\build-application\\b2b\\development"
    }
  }
}
